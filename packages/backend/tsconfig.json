{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",                  // Archivos dentro del directorio `src`
    "../eliza-starter/dist/**/*"// Incluye el directorio `eliza-starter/src`
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}